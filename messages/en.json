{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"cv_page_title": "CV | {name}",
	"cv_contact_email": "Email",
	"cv_contact_github": "GitHub",
	"cv_contact_linkedin": "LinkedIn",
	"series_medium_film": "Film",
	"series_medium_animation": "Animation",
	"series_medium_anime": "Anime",
	"series_medium_donghua": "Donghua",
	"series_medium_novel": "Novel",
	"series_medium_comics": "Comics",
	"series_medium_manga": "Manga",
	"series_medium_manhua": "Manhua",
	"series_medium_manhwa": "Manhwa",
	"series_link_anidb": "AniDB",
	"series_link_mangaupdates": "MangaUpdates",
	"series_link_novelupdates": "Novel Updates",
	"series_link_mydramalist": "MyDramaList",
	"series_page_title": "Series Recs. | {name}",
	"series_page_header_title": "Series I Recommend",
	"series_page_header_description": "A collection of films, comics, and other works you may enjoy.",
	"series_column_title": "Title",
	"series_column_medium": "Medium",
	"series_column_rating": "Rating",
	"series_column_links": "Links",
	"cv_date_single": [
		{
			"declarations": [
				"input date",
				"input dateStatus",
				"local formattedDate = date: datetime month=long year=numeric timeZone=UTC"
			],
			"selectors": [
				"dateStatus"
			],
			"match": {
				"dateStatus=completed": "{formattedDate}",
				"dateStatus=expected": "Expected {formattedDate}"
			}
		}
	],
	"cv_date_range": [
		{
			"declarations": [
				"input endDate",
				"input endDateStatus",
				"input startDate",
				"input startDateStatus",
				"local formattedEndDate = endDate: datetime month=long year=numeric timeZone=UTC",
				"local formattedStartDate = startDate: datetime month=long year=numeric timeZone=UTC"
			],
			"selectors": [
				"endDateStatus",
				"startDateStatus"
			],
			"match": {
				"endDateStatus=completed, startDateStatus=completed": "{formattedStartDate} – {formattedEndDate}",
				"endDateStatus=present, startDateStatus=completed": "{formattedStartDate} – Present",
				"endDateStatus=completed, startDateStatus=present": "{formattedEndDate}",
				"endDateStatus=expected, startDateStatus=present": "Expected {formattedEndDate}"
			}
		}
	],
	"proud_early_porpoise_fold": "Experience",
	"wacky_sad_loris_inspire": "GitHub"
}
